# ── SendGrid (contact form) ───────────────────────────────────────────────
# Copy this file to .env.local and fill in the values. Never commit real keys.

# API key with "Mail Send" permission — SendGrid → Settings → API Keys
SENDGRID_API_KEY=

# Verified Single Sender address (must be verified in SendGrid)
CONTACT_FROM_EMAIL=hello@integispay.com

# Where contact-form leads are delivered
CONTACT_TO_EMAIL=hello@integispay.com
